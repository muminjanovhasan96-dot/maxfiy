# ───────────────────────────────────────────────────────────────────────────
# Maxfiy configuration. Copy to `.env.local` and fill in as needed.
# The DEFAULT (everything below left blank) runs a fully on-device vault with
# ZERO external services. Cloud settings are only needed for a deployed,
# multi-device vault. In every mode the server only ever sees ciphertext.
# ───────────────────────────────────────────────────────────────────────────

# Storage backend: "local" (default, IndexedDB on-device) or "cloud".
NEXT_PUBLIC_STORAGE=local

# ─── Cloud mode: Postgres metadata (Neon or any Postgres) ──────────────────
# Stores only ciphertext + wrapped keys. Never plaintext.
DATABASE_URL=

# ─── Cloud mode: encrypted blob storage (Vercel Blob) ──────────────────────
# Auto-injected on Vercel when you attach a Blob store; paste one for local testing.
BLOB_READ_WRITE_TOKEN=

# ─── Cloud mode: owner API gate ────────────────────────────────────────────
# A short code entered once per device to open an API session. This is NOT one
# of your two vault passwords — it only protects the ciphertext store from
# anonymous access. Your encryption is what keeps the data secret.
OWNER_ACCESS_CODE=
# 32+ random characters used to sign the httpOnly session cookie.
SESSION_SECRET=

# ─── Brute-force lockout durability (recommended in production) ─────────────
# With Upstash, the 2-attempt / 15-minute lockout is enforced durably across
# serverless instances. Without it, lockout uses per-instance memory (dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
